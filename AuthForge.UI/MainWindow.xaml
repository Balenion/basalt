<Window x:Class="AuthForge.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AuthForge.UI" 
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="AuthForge" Height="700" Width="1200"
        WindowStyle="None" 
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen" Icon="/Icons/icon_auth_forge.ico">
    <Border Margin="10" 
        Background="{DynamicResource MaterialDesignPaper}" 
        CornerRadius="15" 
        x:Name="MainBorder"
        BorderThickness="1"
        BorderBrush="{DynamicResource PrimaryHueLightBrush}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>
        <Grid Background="#1A1A1A">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <materialDesign:ColorZone Mode="PrimaryMid" 
                                  CornerRadius="15,15,0,0" 
                                  Padding="12" 
                                  x:Name="TitleBar"
                                  MouseDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <materialDesign:PackIcon Kind="ShieldKey" Width="28" Height="28" 
                                             VerticalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="AUTHFORGE" 
                               Margin="12,0,0,0" 
                               VerticalAlignment="Center" 
                               FontSize="18" 
                               FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="White" Margin="0,0,5,0"
                                Width="40" Padding="0" Click="ChangeLanguage_Click">
                            <Button.ToolTip>
                                <ToolTip Content="{DynamicResource m_TipChangeLanguage}"/>
                            </Button.ToolTip>
                            <materialDesign:PackIcon Kind="Translate" Width="20" Height="20" VerticalAlignment="Center"/>
                        </Button>

                        <materialDesign:PopupBox PlacementMode="BottomAndAlignRightEdges" StaysOpen="False"
                                             Margin="0,0,10,0">
                            <materialDesign:PopupBox.ToggleContent>
                                <materialDesign:PackIcon Kind="InformationOutline" 
                                                     Width="24" 
                                                     Height="24" 
                                                     Foreground="OrangeRed"/>
                            </materialDesign:PopupBox.ToggleContent>
                            <Border Background="#1A1A1A" BorderBrush="Cyan" BorderThickness="1" 
                                Width="280" CornerRadius="8" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="AUTHFORGE v1.0" FontSize="16" 
                                           FontWeight="Bold" Foreground="Cyan" Margin="0,0,0,10"/>
                                    <Separator Background="Cyan" Opacity="0.3" Margin="0,0,0,10"/>
                                    <TextBlock Text="{DynamicResource m_SuiteName}" FontStyle="Italic" 
                                           Foreground="White" Opacity="0.8" TextWrapping="Wrap"/>
                                    <TextBlock Text="{DynamicResource m_TechStack}" Margin="0,15,0,5" FontWeight="SemiBold" 
                                           Foreground="OrangeRed"/>
                                    <TextBlock Text="• .NET 10 WPF&#x0a;• Argon2id / BCrypt&#x0a;• ClosedXML Engine" 
                                           FontSize="11" Foreground="White" Opacity="0.7"/>
                                    <TextBlock Text="© 2026 Balenion" Margin="0,20,0,0" 
                                           FontSize="10" HorizontalAlignment="Right" Foreground="Cyan"/>
                                </StackPanel>
                            </Border>
                        </materialDesign:PopupBox>
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Content="{materialDesign:PackIcon Kind=WindowMinimize}"
                            Foreground="White"
                            Click="MinimizeBtn_Click" 
                            Width="50"/>
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Content="{materialDesign:PackIcon Kind=WindowMaximize}"
                            Foreground="White"
                            Click="MaximizeBtn_Click" 
                            Width="50"/>
                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Content="{materialDesign:PackIcon Kind=Close}"
                            Foreground="#FF5F5F"
                            Click="CloseBtn_Click" 
                            Width="50"/>
                    </StackPanel>
                </Grid>
            </materialDesign:ColorZone>

            <TabControl Grid.Row="1" 
                    materialDesign:NavigationRailAssist.ShowSelectionBackground="True"
                    materialDesign:NavigationRailAssist.SelectionCornerRadius="10"
                    Style="{StaticResource MaterialDesignNavigationRailTabControl}"
                    Margin="0,10,0,0" Background="#1A1A1A">

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Width="70">
                            <materialDesign:PackIcon Kind="FileExcel" HorizontalAlignment="Center" Width="24" Height="24"/>
                            <TextBlock Text="{DynamicResource m_TabExcel}" HorizontalAlignment="Center" FontSize="10" Margin="0,4,0,0"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="380"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="{DynamicResource m_FileManagement}" Style="{StaticResource MaterialDesignOverlineTextBlock}" Opacity="0.6"/>
                                <materialDesign:Card Background="#232323" Margin="0,8,0,16" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2">
                                    <StackPanel>
                                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Content="{DynamicResource m_BtnChooseExcel}"
                                            materialDesign:ButtonAssist.CornerRadius="8"
                                            Click="SelectFile_Click"/>
                                        <TextBox Margin="0,12,0,0" 
                                             x:Name="FilePathTxt"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             IsReadOnly="True" FontSize="12" Text="{DynamicResource m_NoFileSelected}"/>
                                    </StackPanel>
                                </materialDesign:Card>
                                <materialDesign:Card Background="#232323" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource m_NoFileQuestion}" Style="{StaticResource MaterialDesignBody2TextBlock}" Margin="0,0,0,8"/>
                                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                            Content="{DynamicResource m_BtnGenerateTemplate}"
                                            materialDesign:ButtonAssist.CornerRadius="8"
                                            Click="CreateTemplate_Click"/>
                                    </StackPanel>
                                </materialDesign:Card>
                                <Button x:Name="StartBtn" Margin="0,32,0,0" Height="60" Content="{DynamicResource m_BtnStartForging}" 
                                    FontSize="18" FontWeight="Bold" IsEnabled="False"
                                    Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                                    materialDesign:ButtonAssist.CornerRadius="12"
                                    Click="StartHashing_Click">
                                    <Button.ToolTip>
                                        <ToolTip Content="{DynamicResource m_TipStartForging}"/>
                                    </Button.ToolTip>
                                </Button>
                            </StackPanel>

                            <materialDesign:Card Grid.Column="1" Padding="24" Background="#232323" materialDesign:ElevationAssist.Elevation="Dp4">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource m_AlgoConfig}" Style="{StaticResource MaterialDesignOverlineTextBlock}" Opacity="0.6" Margin="0,0,0,16"/>
                                    <ComboBox x:Name="AlgoSelector" Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          FontSize="16" SelectedIndex="0" SelectionChanged="AlgoSelector_SelectionChanged">
                                        <ComboBoxItem Content="Argon2id (Recommended)"/>
                                        <ComboBoxItem Content="BCrypt"/>
                                        <ComboBoxItem Content="PBKDF2 (.NET Built-in)"/>
                                        <ComboBoxItem Content="SHA256 (Legacy)"/>
                                    </ComboBox>

                                    <StackPanel x:Name="Argon2Settings" Margin="0,24,0,0">
                                        <TextBlock Text="{DynamicResource m_ArgonParams}" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16" Foreground="White"/>
                                        <Grid Margin="0,0,0,20">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{DynamicResource m_ParamMemory}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ElementName=MemorySlider, Path=Value, StringFormat={}{0} MB}" 
                                                           HorizontalAlignment="Right" FontWeight="Bold" Foreground="White"/>
                                                </DockPanel>
                                                <Slider ValueChanged="MemorySlider_ValueChanged" x:Name="MemorySlider" Minimum="16" Maximum="512" Value="64" TickFrequency="16" IsSnapToTickEnabled="True" Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,0,0,20">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{DynamicResource m_ParamIterations}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ElementName=IterSlider, Path=Value}" 
                                                           HorizontalAlignment="Right" FontWeight="Bold" Foreground="White"/>
                                                </DockPanel>
                                                <Slider x:Name="IterSlider" ValueChanged="IterSlider_ValueChanged" Minimum="1" Maximum="20" Value="4" 
                                                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid>
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{DynamicResource m_ParamParallelism}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ElementName=ThreadSlider, Path=Value}" 
                                                           HorizontalAlignment="Right" FontWeight="Bold" Foreground="White"/>
                                                </DockPanel>
                                                <Slider x:Name="ThreadSlider" Minimum="1" ValueChanged="ThreadSlider_ValueChanged"
                                                        Maximum="16" Value="8" Margin="0,8,0,0"
                                                        TickFrequency="1" IsSnapToTickEnabled="True"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel x:Name="BCryptSettings" Margin="0,24,0,0" Visibility="Collapsed">
                                        <TextBlock Text="{DynamicResource m_BCryptParams}" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16" Foreground="White"/>
                                        <Grid Margin="0,0,0,20">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{DynamicResource m_ParamWorkFactor}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ElementName=WorkFactorSlider, Path=Value}" 
                                                               HorizontalAlignment="Right" FontWeight="Bold" Foreground="White"/>
                                                </DockPanel>
                                                <Slider x:Name="WorkFactorSlider" Minimum="4" Maximum="15" Value="11" 
                                                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,8,0,0"
                                                        ValueChanged="WorkFactorSlider_ValueChanged"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel x:Name="PBKDF2Settings" Margin="0,24,0,0" Visibility="Collapsed">
                                        <TextBlock Text="Параметры PBKDF2" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16" Foreground="White"/>

                                        <Grid Margin="0,0,0,20">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource m_ParamPRF}" Margin="0,0,0,8"/>
                                                <ComboBox x:Name="Pbkdf2AlgoSelector" SelectedIndex="0" 
                                                          Foreground="White" SelectionChanged="Pbkdf2AlgoSelector_SelectionChanged"
                                                          Style="{StaticResource MaterialDesignOutlinedComboBox}">
                                                    <ComboBoxItem Content="SHA256"/>
                                                    <ComboBoxItem Content="SHA512"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,0,0,20">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{DynamicResource m_ParamNumberOfIterations}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ElementName=Pbkdf2IterSlider, Path=Value, StringFormat={}{0:N0}}" 
                                                               HorizontalAlignment="Right" FontWeight="Bold" Foreground="White"/>
                                                </DockPanel>
                                                <Slider x:Name="Pbkdf2IterSlider" 
                                                        Minimum="100000" 
                                                        Maximum="1000000" 
                                                        Value="600000" 
                                                        TickFrequency="50000" 
                                                        IsSnapToTickEnabled="True" 
                                                        Margin="0,8,0,0" ValueChanged="Pbkdf2IterSlider_ValueChanged"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel x:Name="LegacySettings" Margin="0,24,0,0" Visibility="Collapsed">
                                        <materialDesign:Card Background="#33FF5252" Padding="12" Margin="0,0,0,16">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Alert" Foreground="#FF5252" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource m_WarningSHA256}" 
                                                       Margin="10,0,0,0" Foreground="#FF5252" TextWrapping="Wrap" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                            </StackPanel>
                                        </materialDesign:Card>
                                        <TextBlock Text="{DynamicResource m_LegacyOptions}" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,8"/>
                                        <CheckBox x:Name="UseSaltLegacy" Content="{DynamicResource m_UseSalt}" 
                                              IsChecked="True" Checked="UseSaltLegacy_Checked" Unchecked="UseSaltLegacy_Unchecked" Style="{StaticResource MaterialDesignDarkCheckBox}"/>
                                    </StackPanel>
                                    <StackPanel x:Name="ProgressArea" Visibility="Collapsed" Margin="0,40,0,0">
                                        <TextBlock x:Name="StatusTxt" Text="{DynamicResource m_StatusProgress}" Margin="0,0,0,8" Opacity="0.7"/>
                                        <ProgressBar x:Name="HashProgress" Value="0" Height="10" 
                                                 Style="{StaticResource MaterialDesignLinearProgressBar}"/>
                                    </StackPanel>
                                </StackPanel>
                            </materialDesign:Card>
                        </Grid>
                    </Border>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Width="70">
                            <materialDesign:PackIcon Kind="Fingerprint" HorizontalAlignment="Center" Width="24" Height="24"/>
                            <TextBlock Text="{DynamicResource m_TabSingle}" HorizontalAlignment="Center" FontSize="10" Margin="0,4,0,0"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="400"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="{DynamicResource m_InputData}" Style="{StaticResource MaterialDesignOverlineTextBlock}" Opacity="0.6" Margin="0,0,0,8"/>
                                <materialDesign:Card Background="#232323" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2">
                                    <StackPanel>
                                        <PasswordBox x:Name="SinglePasswordBox" materialDesign:HintAssist.Hint="{DynamicResource m_HintEnterPassword}"
                                                 Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}"
                                                 FontSize="16"/>
                                        <materialDesign:Card Padding="12" Margin="0,0,0,16" Background="{DynamicResource PrimaryHueLightBrush}" Opacity="0.9">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource m_CurrentConfig}" FontSize="10" FontWeight="Bold" Opacity="0.6"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <materialDesign:PackIcon Kind="SettingsInputComponent" VerticalAlignment="Center" Width="16"/>
                                                    <TextBlock x:Name="ActiveMethodTxt" Text="Argon2id" Margin="8,0,0,0" FontSize="14" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <TextBlock x:Name="ActiveDetailsTxt" Text="64MB, 4 Iterations" FontSize="11" Opacity="0.7" Margin="24,2,0,0"/>
                                            </StackPanel>
                                        </materialDesign:Card>
                                        <Button Margin="0,20,0,0" Content="{DynamicResource m_BtnGenerateHash}" Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                                            Click="GenerateSingleHash_Click" Height="45"/>
                                    </StackPanel>
                                </materialDesign:Card>
                                <TextBlock Text="{DynamicResource m_SettingsReused}" Margin="0,20,0,0" 
                                       FontSize="10" HorizontalAlignment="Center" Opacity="0.5"/>
                            </StackPanel>
                            <materialDesign:Card Background="#232323" Grid.Column="1" Padding="24" materialDesign:ElevationAssist.Elevation="Dp4">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource m_ResultInspector}" Style="{StaticResource MaterialDesignOverlineTextBlock}" Opacity="0.6" Margin="0,0,0,16"/>
                                    <TextBlock Text="{DynamicResource m_PassHash}" Opacity="0.6" FontSize="12"/>
                                    <Grid Margin="0,4,0,16">
                                        <TextBox x:Name="ResultHashTxt" Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                             IsReadOnly="True" TextWrapping="Wrap" 
                                             VerticalAlignment="Top" AcceptsReturn="True"
                                             MinHeight="80" FontSize="14" FontWeight="Medium"/>
                                        <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                                             Margin="0,8,8,0" Padding="4" Height="30" Width="30"
                                             Style="{StaticResource MaterialDesignToolForegroundButton}"
                                             Click="CopyHash_Click" ToolTip="{DynamicResource m_TipCopyHash}">
                                            <materialDesign:PackIcon Kind="ContentCopy" Width="18" Height="18"/>
                                        </Button>
                                    </Grid>
                                    <TextBlock Text="{DynamicResource m_SaltBase64}" Opacity="0.6" FontSize="12"/>
                                    <Grid Margin="0,4,0,16">
                                        <TextBox x:Name="ResultSaltTxt" Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                             IsReadOnly="True" FontSize="14"/>
                                        <Button HorizontalAlignment="Right" VerticalAlignment="Center" 
                                             Margin="0,0,8,0" Padding="4" Height="30" Width="30"
                                             Style="{StaticResource MaterialDesignToolForegroundButton}"
                                             Click="CopySalt_Click" ToolTip="{DynamicResource m_TipCopySalt}">
                                            <materialDesign:PackIcon Kind="ContentCopy" Width="18" Height="18"/>
                                        </Button>
                                    </Grid>
                                    <Separator Margin="0,10" Style="{StaticResource MaterialDesignLightSeparator}"/>
                                    <StackPanel Orientation="Horizontal" Opacity="0.7">
                                        <materialDesign:PackIcon Kind="InformationOutline" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="AlgoInfoTxt" Text="{DynamicResource m_InfoAlgoNone}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </materialDesign:Card>
                        </Grid>
                    </Border>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Width="70">
                            <materialDesign:PackIcon Kind="KeyChain" HorizontalAlignment="Center" Width="24" Height="24"/>
                            <TextBlock Text="{DynamicResource m_TabKeys}" HorizontalAlignment="Center" FontSize="10" Margin="0,4,0,0"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="400"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="{DynamicResource m_GenParams}" Style="{StaticResource MaterialDesignOverlineTextBlock}" Opacity="0.6" Margin="0,0,0,8"/>
                                <materialDesign:Card Background="#232323" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource m_KeyLength}" Margin="0,0,0,12" Opacity="0.8"/>
                                        <RadioButton x:Name="Rb128" Content="{DynamicResource m_Rb128}" GroupName="KeySize" Margin="0,0,0,8"/>
                                        <RadioButton x:Name="Rb256" Content="{DynamicResource m_Rb256}" GroupName="KeySize" IsChecked="True" Margin="0,0,0,8"/>
                                        <RadioButton x:Name="Rb512" Content="{DynamicResource m_Rb512}" GroupName="KeySize" Margin="0,0,0,8"/>
                                        <Button Margin="0,24,0,0" Content="{DynamicResource m_BtnGenSecret}" 
                                            Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                                            Click="GenerateKey_Click" Height="45"/>
                                    </StackPanel>
                                </materialDesign:Card>
                                <materialDesign:Card Margin="0,20,0,0" Padding="12" Background="{DynamicResource MaterialDesignTextFieldBox}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Information" Opacity="0.5" VerticalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource m_CryptoNote}" Width="350"
                                               Margin="10,0,0,0" FontSize="10" TextWrapping="Wrap" Opacity="0.6" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </materialDesign:Card>
                            </StackPanel>
                            <materialDesign:Card Background="#232323" Grid.Column="1" Padding="24" materialDesign:ElevationAssist.Elevation="Dp4">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource m_SecretKeyOutput}" Style="{StaticResource MaterialDesignOverlineTextBlock}" Opacity="0.6" Margin="0,0,0,16"/>

                                    <TextBlock Text="{DynamicResource m_Base64Secret}" Opacity="0.6" FontSize="12"/>
                                    <Grid Margin="0,4,0,16">
                                        <TextBox x:Name="GeneratedKeyBase64Txt" Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                                 IsReadOnly="True" TextWrapping="Wrap" Padding="10,10,45,10"
                                                 MinHeight="50" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                        <Button HorizontalAlignment="Right" VerticalAlignment="Center" 
                                                Margin="0,0,8,0" Padding="4" Height="30" Width="30"
                                                Style="{StaticResource MaterialDesignToolForegroundButton}"
                                                Click="CopyBase64_Click" ToolTip="{DynamicResource m_TipCopyKey}">
                                            <materialDesign:PackIcon Kind="ContentCopy" Width="18" Height="18"/>
                                        </Button>
                                    </Grid>

                                    <TextBlock Text="{DynamicResource m_HexSecret}" Opacity="0.6" FontSize="12"/>
                                    <Grid Margin="0,4,0,16">
                                        <TextBox x:Name="GeneratedKeyHexTxt" Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                                 IsReadOnly="True" TextWrapping="Wrap" Padding="10,10,45,10"
                                                 MinHeight="50" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                        <Button HorizontalAlignment="Right" VerticalAlignment="Center" 
                                                Margin="0,0,8,0" Padding="4" Height="30" Width="30"
                                                Style="{StaticResource MaterialDesignToolForegroundButton}"
                                                Click="CopyHex_Click" ToolTip="{DynamicResource m_TipCopyKey}">
                                            <materialDesign:PackIcon Kind="ContentCopy" Width="18" Height="18"/>
                                        </Button>
                                    </Grid>

                                    <TextBlock Text="{DynamicResource m_TotpKeySecret}" Opacity="0.6" FontSize="12"/>
                                    <Grid Margin="0,4,0,24">
                                        <TextBox x:Name="GeneratedKeyTotpTxt" Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                                 IsReadOnly="True" TextWrapping="Wrap" Padding="10,10,45,10"
                                                 MinHeight="50" FontSize="14" FontWeight="Bold" Foreground="Cyan"/>
                                        <Button HorizontalAlignment="Right" VerticalAlignment="Center" 
                                                Margin="0,0,8,0" Padding="4" Height="30" Width="30"
                                                Style="{StaticResource MaterialDesignToolForegroundButton}"
                                                Click="CopyTotpSecret_Click" ToolTip="{DynamicResource m_TipCopyKey}">
                                            <materialDesign:PackIcon Kind="ContentCopy" Width="18" Height="18"/>
                                        </Button>
                                    </Grid>

                                    <TextBlock Text="{DynamicResource m_UsageGuide}" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,8" FontSize="16"/>
                                    <Border Background="{DynamicResource MaterialDesignDivider}" Height="1" Margin="0,0,0,16"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <materialDesign:PackIcon Kind="DotNet" VerticalAlignment="Center" Foreground="White" Width="18" Height="18"/>
                                        <TextBlock Text="{DynamicResource m_GuideJwt}" Margin="12,0,0,0" Opacity="0.8" TextWrapping="Wrap" Width="450"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <materialDesign:PackIcon Kind="Database" VerticalAlignment="Center" Foreground="White" Width="18" Height="18"/>
                                        <TextBlock Text="{DynamicResource m_GuideHex}" Margin="12,0,0,0" Opacity="0.8" TextWrapping="Wrap" Width="450"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <materialDesign:PackIcon Kind="ClockFast" VerticalAlignment="Center" Foreground="White" Width="18" Height="18"/>
                                        <TextBlock Text="{DynamicResource m_GuideTotp}" Margin="12,0,0,0" Opacity="0.8" TextWrapping="Wrap" Width="450"/>
                                    </StackPanel>
                                </StackPanel>
                            </materialDesign:Card>
                        </Grid>
                    </Border>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Width="70">
                            <materialDesign:PackIcon Kind="TwoFactorAuthentication" HorizontalAlignment="Center" Width="24" Height="24"/>
                            <TextBlock Text="{DynamicResource m_Tab2FA}" HorizontalAlignment="Center" FontSize="10" Margin="0,4,0,0"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="400"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="{DynamicResource m_TotpConfig}" Style="{StaticResource MaterialDesignOverlineTextBlock}" Opacity="0.6" Margin="0,0,0,8"/>
                                <materialDesign:Card Background="#232323" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2">
                                    <StackPanel>
                                        <TextBox x:Name="TotpSecretInput" materialDesign:HintAssist.Hint="{DynamicResource m_HintEnterTotpSecret}"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" CaretBrush="White"
                                                 Foreground="White" FontSize="14" MaxLength="128" TextChanged="TotpSecretInput_TextChanged"/>

                                        <Button Margin="0,20,0,0" Content="{DynamicResource m_BtnActivateTotp}" Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                                                materialDesign:ButtonAssist.CornerRadius="8" Click="ActivateTotp_Click" Height="45"/>
                                    </StackPanel>
                                </materialDesign:Card>

                                <materialDesign:Card Margin="0,20,0,0" Padding="12" Background="{DynamicResource MaterialDesignTextFieldBox}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Information" Opacity="0.5" VerticalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource m_TotpNote}" Width="340"
                                                   Margin="10,0,0,0" FontSize="10" TextWrapping="Wrap" Opacity="0.6" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </materialDesign:Card>
                            </StackPanel>

                            <materialDesign:Card x:Name="TotpDisplayCard" Visibility="Collapsed" Background="#232323" Grid.Column="1" Padding="24" materialDesign:ElevationAssist.Elevation="Dp4">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource m_TotpLiveOutput}" Style="{StaticResource MaterialDesignOverlineTextBlock}" Opacity="0.6" Margin="0,0,0,16"/>

                                    <Border Background="#1A1A1A" BorderBrush="Cyan" BorderThickness="1" CornerRadius="12" Padding="30" HorizontalAlignment="Center" Width="320">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock x:Name="TotpCodeTxt" Text="000 000" FontSize="46" 
                                                       FontWeight="Bold" 
                                                       Foreground="Cyan" 
                                                       HorizontalAlignment="Center"/>

                                            <TextBlock x:Name="TotpCountdownTxt" Text="--" FontSize="13" Foreground="White" 
                                                       Opacity="0.5" HorizontalAlignment="Center" Margin="0,12,0,16"/>

                                            <ProgressBar x:Name="TotpTimeProgress" Minimum="0" Maximum="30" Value="30" Height="6" 
                                                         Foreground="Cyan" Background="#333333" Width="220"
                                                         HorizontalAlignment="Center" Style="{StaticResource MaterialDesignLinearProgressBar}"/>
                                        </StackPanel>
                                    </Border>

                                    <Button Margin="0,24,0,0" 
                                            Style="{StaticResource MaterialDesignFlatButton}" 
                                            Foreground="Cyan"
                                            HorizontalAlignment="Center"
                                            Click="CopyTotpCode_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ContentCopy" Width="18" Height="18" VerticalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource m_BtnCopyTotpCode}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </materialDesign:Card>
                        </Grid>
                    </Border>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Width="70">
                            <materialDesign:PackIcon Kind="Database" HorizontalAlignment="Center" Width="24" Height="24"/>
                            <TextBlock Text="{DynamicResource m_TabSeedGen}" HorizontalAlignment="Center" FontSize="10" Margin="0,4,0,0"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="420"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource m_SeedParams}" Style="{StaticResource MaterialDesignOverlineTextBlock}" Opacity="0.6" Margin="0,0,0,8"/>
                                    <materialDesign:Card Background="#232323" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Margin="0,0,0,4" Opacity="0.8">
                                                       <Run Text="{DynamicResource m_UserCount}"/>: 
                                                       <Run Text="{Binding ElementName=SliderUserCount, Path=Value}" FontWeight="Bold" Foreground="Cyan"/>
                                            </TextBlock>
                                            <Slider x:Name="SliderUserCount" Minimum="10" Maximum="1000" Value="100" TickFrequency="10" IsSnapToTickEnabled="True" Margin="0,0,0,16"/>

                                            <TextBlock Margin="0,0,0,4" Opacity="0.8">
                                                       <Run Text="{DynamicResource m_GeneratedPassLength}"/>: 
                                                       <Run Text="{Binding ElementName=SliderPassLength, Path=Value}" FontWeight="Bold" Foreground="Cyan"/>
                                            </TextBlock>
                                            <Slider x:Name="SliderPassLength" Minimum="8" Maximum="32" Value="14" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,16"/>
                                        </StackPanel>
                                    </materialDesign:Card>

                                    <TextBlock Text="{DynamicResource m_AdditionalFields}" Style="{StaticResource MaterialDesignOverlineTextBlock}" Opacity="0.6" Margin="0,4,0,8"/>
                                    <materialDesign:Card Background="#232323" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2" Margin="0,0,0,16">
                                        <StackPanel>
                                            <CheckBox x:Name="CbName" Content="{DynamicResource m_FieldFullName}" Margin="0,0,0,8" Checked="CbName_Changed" Unchecked="CbName_Changed"/>

                                            <CheckBox x:Name="CbSplitName" Content="{DynamicResource m_FieldSplitName}" Margin="24,0,0,12" FontSize="12" IsEnabled="False" Opacity="0.5"/>

                                            <CheckBox x:Name="CbEmail" Content="{DynamicResource m_FieldEmail}" Margin="0,0,0,12"/>
                                            <CheckBox x:Name="CbPhone" Content="{DynamicResource m_FieldPhone}" Margin="0,0,0,12"/>
                                            <CheckBox x:Name="CbBirth" Content="{DynamicResource m_FieldBirth}" Margin="0,0,0,12"/>
                                            <CheckBox x:Name="CbRole" Content="{DynamicResource m_FieldRole}" Margin="0,0,0,12"/>
                                            <CheckBox x:Name="CbStatus" Content="{DynamicResource m_FieldStatus}" Margin="0,0,0,16"/>

                                            <Border Background="{DynamicResource MaterialDesignDivider}" Height="1" Margin="0,0,0,16"/>

                                            <CheckBox x:Name="Cb2FA" Content="{DynamicResource m_Field2FA}" Margin="0,0,0,8"/>
                                            <StackPanel IsEnabled="{Binding ElementName=Cb2FA, Path=IsChecked}">
                                                <TextBlock Margin="0,4,0,4" Opacity="0.8" FontSize="12">
                                                          <Run Text="{DynamicResource m_TotpSaturation}"/>: 
                                                          <Run Text="{Binding ElementName=SliderTotpPercent, Path=Value}" FontWeight="Bold" Foreground="Orange"/>%
                                                </TextBlock>
                                                <Slider x:Name="SliderTotpPercent" Minimum="10" Maximum="100" Value="30" TickFrequency="5" IsSnapToTickEnabled="True"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </materialDesign:Card>

                                    <Button Content="{DynamicResource m_BtnGenerateSeed}" Style="{StaticResource MaterialDesignRaisedSecondaryButton}" Click="GenerateSeed_Click" Height="45" Margin="0,4,0,24"/>
                                </StackPanel>
                            </ScrollViewer>

                            <materialDesign:Card Background="#232323" Grid.Column="1" Padding="24" materialDesign:ElevationAssist.Elevation="Dp4" VerticalAlignment="Top" Margin="10,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource m_SeedWorkflowTitle}" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,8" FontSize="16"/>
                                    <Border Background="{DynamicResource MaterialDesignDivider}" Height="1" Margin="0,0,0,16"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <materialDesign:PackIcon Kind="Numeric1Circle" VerticalAlignment="Center" Foreground="Cyan" Width="20" Height="20"/>
                                        <TextBlock Text="{DynamicResource m_SeedStep1}" Margin="12,0,0,0" Opacity="0.8" TextWrapping="Wrap" Width="430"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <materialDesign:PackIcon Kind="Numeric2Circle" VerticalAlignment="Center" Foreground="Cyan" Width="20" Height="20"/>
                                        <TextBlock Text="{DynamicResource m_SeedStep2}" Margin="12,0,0,0" Opacity="0.8" TextWrapping="Wrap" Width="430"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <materialDesign:PackIcon Kind="Numeric3Circle" VerticalAlignment="Center" Foreground="Cyan" Width="20" Height="20"/>
                                        <TextBlock Text="{DynamicResource m_SeedStep3}" Margin="12,0,0,0" Opacity="0.8" TextWrapping="Wrap" Width="430"/>
                                    </StackPanel>

                                    <materialDesign:Card Margin="0,16,0,0" Padding="12" Background="{DynamicResource MaterialDesignTextFieldBox}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ShieldCheck" Foreground="LightGreen" VerticalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource m_SeedZeroKnowledgeNote}" Width="400" Margin="10,0,0,0" FontSize="11" TextWrapping="Wrap" Opacity="0.7"/>
                                        </StackPanel>
                                    </materialDesign:Card>
                                </StackPanel>
                            </materialDesign:Card>
                        </Grid>
                    </Border>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Width="70">
                            <materialDesign:PackIcon Kind="ShieldKeyOutline" HorizontalAlignment="Center" Width="24" Height="24"/>
                            <TextBlock Text="{DynamicResource m_JwtTabTitle}" HorizontalAlignment="Center" FontSize="10" Margin="0,4,0,0"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="450"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="{DynamicResource m_JwtInputTitle}" Style="{StaticResource MaterialDesignOverlineTextBlock}" Opacity="0.6" Margin="0,0,0,8"/>
                                <TextBox x:Name="TxtJwtInput" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Height="220" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                         materialDesign:HintAssist.Hint="Paste encoded JWT token here..." FontSize="12"
                                         TextChanged="TxtJwtInput_TextChanged"/>

                                <TextBlock Text="{DynamicResource m_JwtVerificationTitle}" Style="{StaticResource MaterialDesignOverlineTextBlock}" Opacity="0.6" Margin="0,16,0,8"/>
                                <materialDesign:Card Background="#232323" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2">
                                    <StackPanel>
                                        <TextBox x:Name="TxtJwtSecret" Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                                 materialDesign:HintAssist.Hint="Signature Verification Secret" Foreground="White"
                                                 Margin="0,0,0,16" TextChanged="TxtJwtSecret_TextChanged"/>

                                        <Border x:Name="BorderSigStatus" Background="#2D2D2D" CornerRadius="4" Padding="12,8">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon x:Name="IconSigStatus" Kind="HelpCircleOutline" Foreground="Gray" VerticalAlignment="Center" Width="20" Height="20"/>
                                                <TextBlock x:Name="TxtSigStatus" Text="{DynamicResource m_JwtStatusWaiting}" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </materialDesign:Card>
                            </StackPanel>

                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="160"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="50"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                    <TextBlock Text="HEADER: ALGORITHM &amp; TOKEN TYPE" Style="{StaticResource MaterialDesignOverlineTextBlock}" Foreground="Orange" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtJwtHeader" Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="125"
                                             IsReadOnly="True" FontFamily="Consolas" FontSize="12" Background="#1E1E1E" Foreground="Orange"
                                             VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                                </StackPanel>

                                <Grid Grid.Row="1" Margin="0,0,0,12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="PAYLOAD: DATA / CLAIMS" Style="{StaticResource MaterialDesignOverlineTextBlock}" Foreground="LightBlue" Margin="0,0,0,4"/>
                                    <TextBox Grid.Row="1" x:Name="TxtJwtPayload" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             IsReadOnly="True" FontFamily="Consolas" FontSize="12" Background="#1E1E1E" Foreground="Cyan"
                                             VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                                </Grid>

                                <materialDesign:Card Grid.Row="2" Background="#1A1A1A" Padding="12,4" VerticalAlignment="Center">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <materialDesign:PackIcon Kind="ClockOutline" VerticalAlignment="Center" Opacity="0.6"/>
                                            <TextBlock x:Name="TxtJwtExp" Text="Expiration: —" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.8" FontSize="12"/>
                                        </StackPanel>
                                        <TextBlock x:Name="TxtJwtAlgorithm" Text="Algorithm: —" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.6" FontSize="12" FontWeight="Bold"/>
                                    </Grid>
                                </materialDesign:Card>
                            </Grid>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
